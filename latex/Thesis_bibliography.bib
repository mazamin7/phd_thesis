	file = {PDF:D\:\\Shared\\OneDrive - Politecnico di Milano\\biblioteca\\scienza\\zotero\\storage\\AAGRRCL4\\Kleiner - 2005 - Speech intelligibility in real and simulated sound fields.pdf:application/pdf},
}

@article{nakagawa_improved_1993,
	title = {An improved geometrical sound field analysis in rooms using scattered sound and an audible room acoustic simulator},
