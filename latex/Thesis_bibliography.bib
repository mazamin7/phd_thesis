@article{chandak_efficient_2011,
	title = {Efficient {Auralization} for {Moving} {Sources} and {Receiver}},
	abstract = {We address the problem of generating smooth, spatialized sound for interactive multimedia applications, such as VoIPenabled virtual environments and video games. Such applications have moving sound sources as well as moving receiver (MS-MR). As a receiver moves, it receives sound emitted from prior positions of a given source. We present an efﬁcient algorithm that can correctly model auralization for MS-MR scenarios by performing sound propagation and signal processing from multiple source positions. Our formulation only needs to compute a portion of the response from various source positions using sound propagation algorithms and can be eﬃciently combined with signal processing techniques to generate smooth, spatialized audio. Moreover, we present an eﬃcient signal processing pipeline, based on block convolution, which makes it easy to combine diﬀerent portions of the response from diﬀerent source positions. Finally, we show that our algorithm can be easily combined with well-known geometric sound propagation methods for eﬃcient auralization in MS-MR scenarios, with a low computational overhead (less than 25\%) over auralization for static sources and a static receiver (SS-SR) scenarios.},
	language = {en},
	author = {Chandak, Anish and Antani, Lakulish and Manocha, Dinesh},
	year = {2011},
	file = {Chandak et al. - 2011 - Efficient Auralization for Moving Sources and Rece.pdf:D\:\\Shared\\OneDrive - Politecnico di Milano\\biblioteca\\scienza\\zotero\\storage\\3K79YIVR\\Chandak et al. - 2011 - Efficient Auralization for Moving Sources and Rece.pdf:application/pdf},
}

