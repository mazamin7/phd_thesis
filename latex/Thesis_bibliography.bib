@article{hornikx_extended_2010,
	title = {The extended {Fourier} pseudospectral time-domain method for atmospheric sound propagation},
	volume = {128},
	issn = {0001-4966, 1520-8524},
	url = {https://pubs.aip.org/jasa/article/128/4/1632/683339/The-extended-Fourier-pseudospectral-time-domain},
	doi = {10.1121/1.3474234},
	abstract = {An extended Fourier pseudospectral time-domain (PSTD) method is presented to model atmospheric sound propagation by solving the linearized Euler equations. In this method, evaluation of spatial derivatives is based on an eigenfunction expansion. Evaluation on a spatial grid requires only two spatial points per wavelength. Time iteration is done using a low-storage optimized six-stage Runge-Kutta method. This method is applied to two-dimensional non-moving media models, one with screens and one for an urban canyon, with generally high accuracy in both amplitude and phase. For a moving atmosphere, accurate results have been obtained in models with both a uniform and a logarithmic wind velocity profile over a rigid ground surface and in the presence of a screen. The method has also been validated for three-dimensional sound propagation over a screen. For that application, the developed method is in the order of 100 times faster than the second-order-accurate FDTD solution to the linearized Euler equations. The method is found to be well suited for atmospheric sound propagation simulations where effects of complex meteorology and straight rigid boundary surfaces are to be investigated.},
	language = {en},
	number = {4},
	urldate = {2024-07-27},
	journal = {The Journal of the Acoustical Society of America},
	author = {Hornikx, Maarten and Waxler, Roger and Forssén, Jens},
	month = oct,
	year = {2010},
	pages = {1632--1646},
	file = {Hornikx et al. - 2010 - The extended Fourier pseudospectral time-domain me.pdf:D\:\\Shared\\OneDrive - Politecnico di Milano\\biblioteca\\scienza\\zotero\\storage\\4YH6CM77\\Hornikx et al. - 2010 - The extended Fourier pseudospectral time-domain me.pdf:application/pdf},
}

