	file = {PDF:D\:\\Shared\\OneDrive - Politecnico di Milano\\biblioteca\\scienza\\zotero\\storage\\VT6H828N\\Hardy e Tyzzer - 1950 - Techniques for Determining Acoustics of Amphitheaters by Scale Model Studies with High Frequency Sou.pdf:application/pdf},
}

