@article{hardy_techniques_1950,
	title = {Techniques for {Determining} {Acoustics} of {Amphitheaters} by {Scale} {Model} {Studies} with {High} {Frequency} {Sounds}},
	volume = {22},
	issn = {0001-4966},
	url = {https://doi.org/10.1121/1.1917209},
	doi = {10.1121/1.1917209},
	abstract = {Techniques are described for high frequency tests used in small scale models of architectural structures. The two models tested simulated large outdoor amphitheaters with open‐sided roof structures. One project, sponsored by the Chicago Park District, was an amphitheater seating 25,000 with roofed area seating approximately 4000. The other was a covered amphitheater for 3000 listeners now under construction at Ravinia Park near Chicago. The scales for the models were 16 to 1 and 20 to 1, respectively. Wave‐length similitude was maintained by using proportionally higher frequencies. Steady‐state measurements at frequencies between 2 and 30 kc were made to determine sound levels in the stage area and distribution of sound in the audience area. The effect of an audience was simulated by use of acoustical absorbents. Studies of oscillograph patterns for sound pulses gave information on reverberation times and smoothness of decay curves for various microphone positions. Changes in stage design were needed for both amphitheaters to reduce variations in sound level in the seating area. Observed decay slopes corresponded to reverberation times between 1.4 and 2 sec. in the roofed areas of the prototypes. For the larger amphitheater, the output requirements for the sound amplifying system were determined. The cost of such model studies is found to be under two percent of the construction cost. The results enable the designer to eliminate many costly mistakes.},
	number = {5\_Supplement},
	journal = {The Journal of the Acoustical Society of America},
	author = {Hardy, H. C. and Tyzzer, F. G.},
	month = sep,
	year = {1950},
	note = {\_eprint: https://pubs.aip.org/asa/jasa/article-pdf/22/5\_Supplement/679/18729612/679\_1\_online.pdf},
